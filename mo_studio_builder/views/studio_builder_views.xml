<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mo_studio_builder_field_tree" model="ir.ui.view">
        <field name="name">mo.studio.builder.field.tree</field>
        <field name="model">mo.studio.builder.field</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="technical_name"/>
                <field name="ttype"/>
                <field name="required"/>
                <field name="readonly"/>
                <field name="relation_model_id" invisible="ttype not in ['many2one', 'many2many']" required="ttype in ['many2one', 'many2many']"/>
                <field name="selection_options" invisible="ttype != 'selection'"/>
                <field name="ir_field_id" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="view_mo_studio_builder_field_form" model="ir.ui.view">
        <field name="name">mo.studio.builder.field.form</field>
        <field name="model">mo.studio.builder.field</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="technical_name"/>
                            <field name="ttype"/>
                            <field name="required"/>
                            <field name="readonly"/>
                        </group>
                        <group>
                            <field name="relation_model_id" invisible="ttype not in ['many2one', 'many2many']" required="ttype in ['many2one', 'many2many']"/>
                            <field name="help"/>
                            <field name="ir_field_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Selection Options" invisible="ttype != 'selection'">
                        <field name="selection_options" nolabel="1" placeholder="yes:Yes&#10;no:No&#10;or: نعم:نعم, لا:لا"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mo_studio_builder_app_tree" model="ir.ui.view">
        <field name="name">mo.studio.builder.app.tree</field>
        <field name="model">mo.studio.builder.app</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="technical_name"/>
                <field name="state"/>
                <field name="custom_field_count"/>
                <field name="view_count"/>
                <field name="menu_id"/>
            </tree>
        </field>
    </record>

    <record id="view_mo_studio_builder_app_form" model="ir.ui.view">
        <field name="name">mo.studio.builder.app.form</field>
        <field name="model">mo.studio.builder.app</field>
        <field name="arch" type="xml">
            <form string="Studio Builder">
                <header>
                    <button name="action_add_suggested_fields" string="Add Suggested Fields" type="object" class="btn-secondary" invisible="state != 'draft'"/>
                    <button name="action_create_app" string="Create Your App" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_open_generated_app" string="Open App" type="object" class="btn-primary" invisible="state != 'created'"/>
                    <button name="action_update_app" string="Update App" type="object" class="btn-primary" invisible="state != 'created'"/>
                    <button name="action_regenerate_views" string="Regenerate Views" type="object" class="btn-secondary" invisible="state != 'created'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,created"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box" invisible="state != 'created'">
                        <button name="action_open_fields" type="object" class="oe_stat_button" icon="fa-list">
                            <field name="custom_field_count" widget="statinfo" string="Fields"/>
                        </button>
                        <button name="action_open_views" type="object" class="oe_stat_button" icon="fa-desktop">
                            <field name="view_count" widget="statinfo" string="Views"/>
                        </button>
                        <button name="action_open_access" type="object" class="oe_stat_button" icon="fa-lock">
                            <span>Access</span>
                        </button>
                        <button name="action_open_automations" type="object" class="oe_stat_button" icon="fa-bolt">
                            <span>Automations</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="App name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="technical_name" placeholder="x_my_app" readonly="state == 'created'"/>
                            <field name="menu_name"/>
                            <field name="menu_icon"/>
                            <field name="menu_icon_filename" invisible="1"/>
                            <field name="menu_icon_upload" widget="image" filename="menu_icon_filename"/>
                        </group>
                        <group invisible="state != 'created'">
                            <field name="model_id"/>
                            <field name="model_name"/>
                            <field name="action_id"/>
                            <field name="menu_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Suggested Features">
                            <group>
                                <group string="Records">
                                    <field name="feature_contact"/>
                                    <field name="feature_user"/>
                                    <field name="feature_date"/>
                                    <field name="feature_date_range"/>
                                    <field name="feature_stage"/>
                                    <field name="feature_tags"/>
                                </group>
                                <group string="Behavior">
                                    <field name="feature_picture"/>
                                    <field name="feature_notes"/>
                                    <field name="feature_company"/>
                                    <field name="feature_monetary"/>
                                    <field name="feature_sorting"/>
                                    <field name="feature_archiving"/>
                                </group>
                            </group>
                        </page>
                        <page string="Fields">
                            <field name="field_line_ids" context="{'default_app_id': id}">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="technical_name"/>
                                    <field name="ttype"/>
                                    <field name="required"/>
                                    <field name="readonly"/>
                                    <field name="relation_model_id" invisible="ttype not in ['many2one', 'many2many']" required="ttype in ['many2one', 'many2many']"/>
                                    <field name="selection_options" invisible="ttype != 'selection'"/>
                                    <field name="help"/>
                                    <field name="ir_field_id" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Designer Shortcuts" invisible="state != 'created'">
                            <group>
                                <group string="Advanced Editors">
                                    <button name="action_update_app" type="object" string="Update App" class="btn-primary"/>
                                    <button name="action_open_fields" type="object" string="Manage Fields" class="btn-secondary"/>
                                    <button name="action_open_views" type="object" string="Manage Views XML" class="btn-secondary"/>
                                </group>
                                <group string="Security &amp; Logic">
                                    <button name="action_open_access" type="object" string="Access Control" class="btn-secondary"/>
                                    <button name="action_open_automations" type="object" string="Automations" class="btn-secondary"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mo_studio_builder_app_search" model="ir.ui.view">
        <field name="name">mo.studio.builder.app.search</field>
        <field name="model">mo.studio.builder.app</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="technical_name"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Created" name="created" domain="[('state', '=', 'created')]"/>
            </search>
        </field>
    </record>

    <record id="action_mo_studio_builder_app" model="ir.actions.act_window">
        <field name="name">Studio Builder</field>
        <field name="res_model">mo.studio.builder.app</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_created': 1}</field>
    </record>

    <menuitem id="menu_mo_studio_builder_root" name="Studio Builder" sequence="5" groups="base.group_system" web_icon="mo_studio_builder,static/description/icon.svg"/>
    <menuitem id="menu_mo_studio_builder_apps" name="App Builder" parent="menu_mo_studio_builder_root" action="action_mo_studio_builder_app" sequence="10" groups="base.group_system"/>
    <menuitem id="menu_mo_studio_generated_apps" name="Generated Apps" parent="menu_mo_studio_builder_root" sequence="20" groups="base.group_system"/>
</odoo>

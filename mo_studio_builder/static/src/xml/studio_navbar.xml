<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.NavBar" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('o_menu_systray')]" position="before">
            <button
                class="o_mo_studio_navbar_btn d-none d-md-inline-flex align-items-center gap-1"
                type="button"
                title="Studio Builder"
                t-on-click="this.openStudioBuilder"
            >
                <i class="fa fa-magic"/>
                <span>Studio</span>
            </button>
        </xpath>
    </t>

    <t t-name="mo_studio_builder.PageEditorDialog">
        <Dialog title="state.title" size="'fs'" fullscreen="true" footer="false" withBodyPadding="false" contentClass="'o_mo_studio_dialog'">
            <div class="o_mo_studio_editor">
                <aside class="o_mo_studio_sidebar">
                    <div class="o_mo_studio_panel_title">Components</div>
                    <div class="o_mo_studio_grid">
                        <button t-foreach="this.fieldTypes" t-as="fieldType" t-key="fieldType[0]"
                                type="button"
                                draggable="true"
                                t-att-class="{'active': state.field.ttype === fieldType[0]}"
                                t-on-click="() => this.selectFieldType(fieldType[0])"
                                t-on-dragstart="(ev) => this.startDrag(ev, fieldType[0])">
                            <i t-att-class="this.fieldIcon(fieldType[0])"/>
                            <span t-esc="fieldType[1]"/>
                        </button>
                    </div>
                    <div class="o_mo_studio_panel_title mt-3">Existing Fields</div>
                    <input class="form-control form-control-sm mb-2" t-model="state.search" placeholder="Search..."/>
                    <div class="o_mo_studio_existing">
                        <div t-foreach="this.filteredFields" t-as="field" t-key="field.id"
                             t-att-class="{'o_mo_studio_existing_field': true, active: state.selectedField &amp;&amp; state.selectedField.name === field.name}"
                             t-on-click="() => this.selectExistingField(field)">
                            <span>
                                <i class="fa fa-tag me-1"/>
                                <t t-esc="field.field_description"/> <small t-esc="field.name"/>
                            </span>
                            <button t-if="field.state === 'manual'" class="btn btn-link text-danger p-0"
                                    type="button" title="Delete custom field"
                                    t-on-click.stop="() => this.removeField(field.name)">
                                <i class="fa fa-trash"/>
                            </button>
                        </div>
                    </div>
                </aside>
                <section class="o_mo_studio_workspace">
                    <div class="o_mo_studio_toolbar">
                        <div>
                            <strong t-esc="state.modelLabel"/>
                            <span class="text-muted ms-2" t-esc="state.model"/>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-secondary btn-sm" t-on-click="this.openFields">Fields</button>
                            <button class="btn btn-secondary btn-sm" t-on-click="this.openViews">Views</button>
                            <button class="btn btn-secondary btn-sm" t-on-click="this.openAutomations">Automations</button>
                            <button class="btn btn-secondary btn-sm" t-on-click="this.openAccess">Access</button>
                            <button class="btn btn-secondary btn-sm" t-on-click="this.openReports">Reports</button>
                            <button class="btn btn-primary btn-sm" t-on-click="this.updatePage" t-att-disabled="state.busy">
                                <i class="fa fa-refresh me-1"/> Update App
                                <span t-if="state.dirty" class="badge text-bg-warning ms-1">Draft</span>
                            </button>
                        </div>
                    </div>
                    <div class="o_mo_studio_canvas">
                        <div class="o_mo_studio_page_shell">
                            <div class="o_mo_studio_page_header">
                                <div>
                                    <small>FORM</small>
                                    <h2 t-esc="state.modelLabel"/>
                                </div>
                                <button class="btn btn-outline-primary btn-sm" t-on-click="() => this.createFieldAt(state.selectedTool)">
                                    <i class="fa fa-plus me-1"/> Insert Selected
                                </button>
                            </div>
                            <div class="o_mo_studio_dropzone"
                                 t-on-dragover="(ev) => ev.preventDefault()"
                                 t-on-drop="(ev) => { ev.preventDefault(); this.dropField(ev, null); }">
                                Drop here to add at the top
                            </div>
                            <div class="o_mo_studio_preview_grid">
                                <t t-foreach="this.previewFields" t-as="field" t-key="field.id">
                                    <div t-att-class="{'o_mo_studio_preview_field': true, active: state.selectedField &amp;&amp; state.selectedField.name === field.name}"
                                         t-on-click="() => this.selectExistingField(field)">
                                        <label>
                                            <span t-esc="field.field_description"/>
                                            <small t-esc="field.ttype"/>
                                        </label>
                                        <div class="o_mo_studio_fake_input">
                                            <t t-esc="this.previewValue(field)"/>
                                        </div>
                                    </div>
                                    <div class="o_mo_studio_dropzone o_mo_studio_dropzone_inline"
                                         t-on-dragover="(ev) => ev.preventDefault()"
                                         t-on-drop="(ev) => { ev.preventDefault(); this.dropField(ev, field.name); }">
                                        Drop after <t t-esc="field.field_description"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                        <aside class="o_mo_studio_properties">
                            <t t-if="state.panel === 'new'">
                                <div class="o_mo_studio_panel_title">New Field</div>
                                <label class="form-label">Label</label>
                                <input class="form-control mb-2" t-model="state.field.name"/>
                                <label class="form-label">Technical Name</label>
                                <input class="form-control mb-2" t-model="state.field.technical_name"/>
                                <label class="form-label">Related Model</label>
                                <input class="form-control mb-2" t-model="state.field.relation_model" t-att-disabled="!['many2one', 'many2many'].includes(state.field.ttype)"/>
                                <label class="form-label">Options</label>
                                <textarea class="form-control mb-2" rows="4" t-model="state.field.selection_options" t-att-disabled="state.field.ttype !== 'selection'"/>
                                <label class="d-block"><input type="checkbox" t-model="state.field.required"/> Required</label>
                                <label class="d-block"><input type="checkbox" t-model="state.field.add_to_form"/> Add to Form</label>
                                <label class="d-block"><input type="checkbox" t-model="state.field.add_to_list"/> Add to List</label>
                                <button class="btn btn-primary w-100 mt-3" t-on-click="this.addField" t-att-disabled="state.busy">Add Field</button>
                            </t>
                            <t t-elif="state.panel === 'properties' and state.selectedField">
                                <div class="o_mo_studio_panel_title">Properties</div>
                                <label class="form-label">Label</label>
                                <input class="form-control mb-2" t-model="state.selectedField.field_description" t-att-disabled="state.selectedField.state !== 'manual'"/>
                                <label class="form-label">Technical Name</label>
                                <input class="form-control mb-2" t-model="state.selectedField.name" disabled="1"/>
                                <label class="form-label">Type</label>
                                <input class="form-control mb-2" t-model="state.selectedField.ttype" disabled="1"/>
                                <label class="form-label">Related Model</label>
                                <input class="form-control mb-2" t-model="state.selectedField.relation" disabled="1"/>
                                <label class="form-label">Selection Options</label>
                                <textarea class="form-control mb-2" rows="5" t-model="state.selectedField.selection_options" t-att-disabled="state.selectedField.state !== 'manual' || state.selectedField.ttype !== 'selection'"/>
                                <label class="form-label">Help</label>
                                <textarea class="form-control mb-2" rows="4" t-model="state.selectedField.help" t-att-disabled="state.selectedField.state !== 'manual'"/>
                                <label class="d-block"><input type="checkbox" t-model="state.selectedField.required" t-att-disabled="state.selectedField.state !== 'manual' || !state.selectedField.can_make_required"/> Required</label>
                                <label class="d-block"><input type="checkbox" t-model="state.selectedField.readonly" t-att-disabled="state.selectedField.state !== 'manual'"/> Readonly</label>
                                <button class="btn btn-primary w-100 mt-3" t-on-click="this.updateSelectedField" t-att-disabled="state.busy || state.selectedField.state !== 'manual'">Save Properties</button>
                                <button class="btn btn-secondary w-100 mt-2" t-on-click="() => this.addSelectedFieldToView('form')" t-att-disabled="state.busy">Add to Form</button>
                                <button class="btn btn-secondary w-100 mt-2" t-on-click="() => this.addSelectedFieldToView('tree')" t-att-disabled="state.busy">Add to List</button>
                            </t>
                            <t t-elif="state.panel === 'fields'">
                                <div class="o_mo_studio_panel_title">Fields</div>
                                <div t-foreach="this.filteredFields" t-as="field" t-key="field.id" class="o_mo_studio_mini_row" t-on-click="() => this.selectExistingField(field)">
                                    <strong t-esc="field.field_description"/><small t-esc="field.name"/>
                                </div>
                            </t>
                            <t t-elif="state.panel === 'views'">
                                <div class="o_mo_studio_panel_title">Views</div>
                                <div t-foreach="state.views" t-as="view" t-key="view.id" class="o_mo_studio_mini_row">
                                    <strong t-esc="view.name"/><small t-esc="view.type"/>
                                </div>
                            </t>
                            <t t-elif="['automations', 'access', 'reports'].includes(state.panel)">
                                <div class="o_mo_studio_panel_title" t-esc="state.panel"/>
                                <p class="text-muted">This editor stays inside Studio. Use the full advanced editor only for deep technical changes.</p>
                            </t>
                            <t t-else="">
                                <div class="o_mo_studio_panel_title">Studio Panel</div>
                                <p class="text-muted">Select a field or component.</p>
                            </t>
                        </aside>
                    </div>
                </section>
            </div>
        </Dialog>
    </t>
</templates>
